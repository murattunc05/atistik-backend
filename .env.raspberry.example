# Copy to .env.raspberry on the Raspberry Pi. Do not commit real secrets.

# Backend persistence / predictions backup.
GITHUB_TOKEN=
GITHUB_ML_REPO=murattunc05/atistik-ml-data

# Automation report repo.
ML_DATA_REPO=murattunc05/atistik-ml-data
ML_DATA_TOKEN=

# Optional: use a fixed timezone in host timers and scripts.
TZ=Europe/Istanbul

# Optional: host-reachable Pi API used for post-job Render parity checks.
ATISTIK_HOST_BACKEND_URL=http://127.0.0.1:5000

# Optional Telegram values are still owned by the existing Telegram bot service.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=-1003547309074
